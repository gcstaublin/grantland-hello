---
const { chat } = Astro.props;
---

<aside
  class="chat-panel"
  id="chat-panel"
  aria-label="The Interrogation chat interface"
>
  <div class="chat-header">
    <div class="chat-title">{chat.panelTitle}</div>
    <div class="chat-status">
      <span class="chat-status-dot active" id="chat-status-dot"></span>
      <span id="chat-status-text">{chat.statusLabel}</span>
    </div>
  </div>

  <div class="chat-messages" id="chat-messages" role="log" aria-live="polite">
    <!-- Messages injected by chat.js -->
  </div>

  <div class="chat-input-area">
    <form class="chat-input-form" id="chat-form" autocomplete="off">
      <input
        type="text"
        class="chat-input"
        id="chat-input"
        placeholder="enter directive..."
        aria-label="Chat input"
        spellcheck="false"
        autocorrect="off"
        autocapitalize="off"
      />
      <button
        type="submit"
        class="chat-submit"
        id="chat-submit"
        aria-label="Send">↵</button
      >
    </form>
  </div>

  <div class="chat-footer">
    <span class="mode-badge" id="mode-badge">CHAT MODE</span>
    <button class="chat-clear-btn" id="chat-clear-btn" type="button">
      // clear history
    </button>
  </div>
</aside>

{/* ================================== */}
{/* Style                              */}
{/* ================================== */}
<style>
  /* ─── Chat Panel ─────────────────────────────────────────── */
  .chat-panel {
    grid-column: 2;
    grid-row: 2;
    display: flex;
    flex-direction: column;
    background: var(--chat-bg);
    border-left: 1px solid var(--border);
    overflow: hidden;
  }

  .chat-header {
    padding: 14px 16px 12px;
    border-bottom: 1px solid var(--chat-border);
    flex-shrink: 0;
  }

  .chat-title {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--text);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .chat-status {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .chat-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  .chat-status-dot.active {
    background: #4caf50;
    box-shadow: 0 0 6px rgba(76, 175, 80, 0.4);
    animation: pulse 2s ease-in-out infinite;
  }

  .chat-status-dot.offline {
    background: #666;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .chat-messages::-webkit-scrollbar {
    width: 3px;
  }
  .chat-messages::-webkit-scrollbar-thumb {
    background: var(--border-light);
    border-radius: 2px;
  }

  /* ─── Chat Message Types ─────────────────────────────────── */
  .chat-msg {
    display: flex;
    flex-direction: column;
    gap: 0;
    animation: msgIn 0.3s ease forwards;
  }

  @keyframes msgIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .chat-msg-system .chat-msg-bubble {
    background: transparent;
    border: 1px solid var(--chat-border);
    padding: 10px 12px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 400;
    line-height: 1.75;
    color: var(--text-dim);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .chat-msg-user {
    align-items: flex-end;
  }

  .chat-msg-user .chat-msg-bubble {
    /* background: var(--chat-surface); */
    background-color: green;
    border: 1px solid var(--border-light);
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--text);
    max-width: 80%;
    word-break: break-word;
  }

  .chat-msg-timestamp {
    font-family: var(--font-mono);
    font-size: 8.5px;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-top: 4px;
    padding: 0 2px;
  }

  .chat-msg-user .chat-msg-timestamp {
    text-align: right;
  }

  /* ─── Chat Input ─────────────────────────────────────────── */
  .chat-input-area {
    padding: 12px 16px;
    border-top: 1px solid var(--chat-border);
    flex-shrink: 0;
  }

  .chat-input-form {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .chat-input {
    flex: 1;
    background: var(--chat-surface);
    border: 1px solid var(--chat-border);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    padding: 9px 12px;
    outline: none;
    transition: border-color 0.2s ease;
    caret-color: var(--text);
  }

  .chat-input:focus {
    border-color: var(--border-light);
  }

  .chat-input::placeholder {
    color: var(--text-muted);
    font-style: normal;
  }

  .chat-input:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .chat-submit {
    background: transparent;
    border: 1px solid var(--chat-border);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 14px;
    padding: 8px 10px;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
    line-height: 1;
    flex-shrink: 0;
  }

  .chat-submit:hover {
    color: var(--text);
    border-color: var(--border-light);
  }

  .chat-submit:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* ─── Chat Footer Actions ────────────────────────────────── */
  .chat-footer {
    padding: 8px 16px 10px;
    border-top: 1px solid var(--chat-border);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-shrink: 0;
  }

  .chat-clear-btn {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 2px 0;
    transition: color 0.2s ease;
    display: none;
  }

  .chat-clear-btn.has-history {
    display: block;
  }

  .chat-clear-btn:hover {
    color: var(--text-dim);
  }
</style>

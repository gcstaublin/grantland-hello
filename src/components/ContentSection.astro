---
interface BodyItem {
  type: "paragraph" | "pullquote" | "image";
  text?: string;
  src?: string;
  alt?: string;
  caption?: string;
}

const { section, isDefault = false } = Astro.props;
---

<section
  class:list={["content-section", { "is-visible": isDefault }]}
  data-section-id={section.id}
  data-keywords={section.keywords.join(",")}
  style={isDefault ? "" : "display: none;"}
>
  <div class="hero-noise hero__noise">
    <div class="section-hero hero" aria-hidden="true">
      {
        section.imgSrc && (
          <figure class="hero__image-block">
            <img
              src={section.imgSrc}
              alt={section.imgAlt || ""}
              loading="lazy"
            />
            {section.imgCaption && (
              <figcaption class="hero__image-caption accent--small">
                {section.imgCaption}
              </figcaption>
            )}
          </figure>
        )
      }
      <div class="hero__type-block">
        <h4 class="section-label accent--micro">
          {section.label}
        </h4>
        <h2 class="section-title section__title display--large">
          {section.title}
        </h2>
      </div>
    </div>
  </div>

  <div class="section-body">
    {
      section.lead && (
        <p class="section-lead body--extra-large">{section.lead}</p>
      )
    }

    {
      section.body && (
        <div class="section-body-content">
          {section.body.map((item: BodyItem) => {
            if (item.type === "pullquote") {
              return (
                <blockquote class="section-pullquote display--medium">
                  {item.text}
                </blockquote>
              );
            } else if (item.type === "image") {
              return (
                <figure class="section-image-block">
                  <img src={item.src} alt={item.alt || ""} loading="lazy" />
                  {item.caption && (
                    <figcaption class="section-image-caption accent--small">
                      {item.caption}
                    </figcaption>
                  )}
                </figure>
              );
            } else {
              return <p class="section-paragraph body--large">{item.text}</p>;
            }
          })}
        </div>
      )
    }

    {
      section.misc && (
        <details class="misc">
          <summary class="misc__title accent--medium">
            {section.miscTitle}
          </summary>
          <ul class="misc__items">
            {section.misc.map((item: string) => (
              <li class="misc__item body--default">{item}</li>
            ))}
          </ul>
        </details>
      )
    }

    {
      section.playlist && (
        <div class="playlist">
          <div class="playlist__embed">
            <iframe
              data-testid="embed-iframe"
              style="border-radius:12px"
              src={section.playlist.embed}
              width="100%"
              height="152"
              frameBorder="0"
              allowfullscreen=""
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
            />
          </div>
          <p class="playlist__text accent--small">{section.playlist.text}</p>
        </div>
      )
    }

    {
      section.tags && (
        <div class="section-tags section__tags">
          {section.tags.map((tag: string) => (
            <span class="section-tag section__tag body--micro">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</section>

{/* ================================== */}
{/* --> Style                          */}
{/* ================================== */}
<style>
  /* Overall Space
  // -------------------------------------------- */
  .section-body > * + * {
    margin-top: 2rem;
  }

  /* Content Section
  // -------------------------------------------- */
  .content-section {
    display: none;
    opacity: 0;
    min-height: calc(100vh - var(--header-h));
    transform: translateY(16px);
    transition:
      opacity 0.45s ease,
      transform 0.45s ease;

    &.is-visible {
      display: block;
      opacity: 1;
      transform: translateY(0);
      margin-bottom: var(--section-space-bottom);
    }

    &.is-leaving {
      display: block;
      opacity: 0;
      transform: translateY(-8px);
      transition:
        opacity 0.25s ease,
        transform 0.25s ease;
      pointer-events: none;
    }
  }

  /* Scroll mode: all sections visible */
  .main-content.scroll-mode .content-section {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  /* Section: Hero Image
  // -------------------------------------------- */
  .section-hero {
    /* padding-block-end: var(--section-body-gap); */
    /* padding-block-end: 1rem; */
  }

  .hero__type-block {
    padding-inline: var(--section-space-inline);

    & > * + * {
      margin-block-start: 1rem;
    }
  }

  .hero__image-block {
    margin: 0;
    margin-block-end: 2rem;
  }

  /* Section: Body
  // -------------------------------------------- */
  .section-body {
    max-width: var(--section-ch);
    padding-inline: var(--section-space-inline);
    /* border: 1px solid red; */
    border-inline: 1px solid var(--border-light);

    container-name: section-body;
    container-type: inline-size;
  }

  .section-body-content {
    columns: 2;
    gap: var(--section-body-gap);
    /* border: 1px solid blue; */

    /* Change number of columns for smaller container size */
    @container section-body (width < 630px) {
      columns: 1;

      /* Change position of caption for smaller containers */
      .section-image-caption {
        --caption-position-left: 0;
        --caption-position-top: -1rem;
      }
    }
  }

  .section-label {
    display: none;
    letter-spacing: 0.18em;
    color: var(--text-muted);
  }

  .section-title {
    padding-inline-start: 3rem;
    text-indent: -3rem;
    /* border: 1px solid red; */
    border-bottom: 1px solid var(--border-light);
  }

  .section-lead {
    max-width: 38ch;
    text-wrap: balance;
  }

  .section-paragraph {
    margin-block: 0;
    text-wrap: pretty;

    &:first-of-type:first-letter {
      initial-letter: 2;
      margin-inline-end: 0.25em;
      font-weight: var(--font-weight-200);
    }
  }

  .section-body-content > *:last-child {
    margin-bottom: 0;
  }

  .section-body-content > * + * {
    margin-block-start: 1.5rem;
  }

  .section-pullquote {
    margin: 28px 0;
    padding-block-end: 1.5rem;
    border-block-end: 1px solid var(--border-light);
  }

  .section-image-block {
    /* margin: 28px 0; */
    position: relative;
    margin-inline: 0;
    /* align-items: center; */
    /* border: 1px solid green; */
    max-inline-size: 40ch;
  }

  .section-image-block img {
    display: block;
    width: 100%;
    height: auto;
    /* max-inline-size: 40ch; */
  }

  .section-image-caption,
  .hero__image-caption {
    --p: 0.35rem; /* control the shape (can be percentage) */
    --caption-position-top: -1.75rem;
    --caption-position-left: 4rem;
    --caption-padding-block: 1.25rem;
    --caption-padding-inline: 1.25rem;
    --caption-margin-end: var(--caption-position-top);

    position: relative;
    top: var(--caption-position-top);
    left: var(--caption-position-left);
    /* max-width: 35ch; */
    padding-block: var(--caption-padding-block);
    padding-inline: var(--caption-padding-inline);
    margin-block-end: var(--caption-margin-end);
    color: var(--text-dim);

    background-color: var(--bg);
    border-radius: 1.25rem;
    corner-shape: bevel square;
    outline-style: solid;
    outline-width: 1px;
    outline-width: 0.5px;
    outline-offset: -6px;
    outline-color: var(--border-light);
  }

  .section-image-caption {
    font-size: 90%;
    font-weight: 300;
  }

  .hero__image-caption {
    max-width: 50ch;
  }

  /* Section: Tags
  // -------------------------------------------- */
  .section__tags {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    padding-top: 20px;
    /* border-top: 1px solid var(--border); */
  }

  .section__tag {
    color: var(--text-muted);
    text-transform: uppercase;
  }

  /* Section: Misc
  // -------------------------------------------- */
  .misc {
    overflow: hidden;
    padding: 1rem;
    padding-inline-start: 3rem;
    padding-block-start: 2rem;
    padding-block-end: 2rem;
    background-color: var(--surface);
    border-radius: 1.25rem;
    corner-shape: bevel square;
    outline-style: solid;
    outline-width: 4px;
    outline-offset: -8px;
    outline-color: var(--bg);

    & > * + * {
      margin-block-start: 1rem;
    }

    &::details-content {
      block-size: 0;
      transition:
        block-size 0.15s ease-in-out,
        content-visibility 0.15s ease-out;
      transition-behavior: allow-discrete;
    }

    &[open]::details-content {
      block-size: auto;
    }
  }

  .misc__title {
    position: relative;
    margin: 0;
    cursor: pointer;
    color: var(--text-utility);
    text-transform: uppercase;
    font-weight: var(--font-weight-500);
    letter-spacing: 0.08em;
    list-style-position: outside;
    transition: all 0.25s;

    &:hover {
      color: var(--text-muted);
    }

    &::marker {
      content: "⏩︎ ";
      color: var(--text-warning);
    }
  }

  /* Misc is open */
  .misc[open] summary::marker {
    content: "⏬︎ ";
  }

  .misc__items {
    & ::marker {
      color: var(--text-warning);
    }
    margin: 0;
    padding: 0;
    list-style-position: outside;
  }

  .misc__item {
    color: var(--text-dim);
  }
</style>

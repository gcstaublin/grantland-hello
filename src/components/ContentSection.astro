---
interface BodyItem {
  type: "paragraph" | "pullquote" | "image";
  text?: string;
  src?: string;
  alt?: string;
  caption?: string;
}

const { section, isDefault = false } = Astro.props;
---

<section
  class:list={["content-section", { "is-visible": isDefault }]}
  data-section-id={section.id}
  data-keywords={section.keywords.join(",")}
  style={isDefault ? "" : "display: none;"}
>
  <div class="hero-noise hero__noise">
    <div class="section-hero hero" aria-hidden="true">
      <!-- <div class="hero-noise"></div> -->
      <!-- <span class="hero-label hero__label accent--micro">{section.label}</span> -->

      {
        section.imgSrc && (
          <figure class="hero__image-block">
            <img
              src={section.imgSrc}
              alt={section.imgAlt || ""}
              loading="lazy"
            />
            {section.imgCaption && (
              <figcaption class="hero__image-caption">
                {section.imgCaption}
              </figcaption>
            )}
          </figure>
        )
      }
      <div class="hero__type-block">
        <h4 class="section-label accent--micro">
          {section.label}
        </h4>
        <h2 class="section-title section__title">{section.title}</h2>
      </div>
    </div>
  </div>

  <div class="section-body">
    <!-- <p class="section-label section__label">{section.label}</p> -->

    {
      section.lead && (
        <p class="section-lead body--extra-large">{section.lead}</p>
      )
    }

    {
      section.body && (
        <div class="section-body-content">
          {section.body.map((item: BodyItem) => {
            if (item.type === "pullquote") {
              return (
                <blockquote class="section-pullquote">{item.text}</blockquote>
              );
            } else if (item.type === "image") {
              return (
                <figure class="section-image-block">
                  <img src={item.src} alt={item.alt || ""} loading="lazy" />
                  {item.caption && (
                    <figcaption class="section-image-caption">
                      {item.caption}
                    </figcaption>
                  )}
                </figure>
              );
            } else {
              return <p class="section-paragraph body--large">{item.text}</p>;
            }
          })}
        </div>
      )
    }

    {
      section.misc && (
        <div class="misc">
          <h3 class="misc__title">Random thoughts</h3>
          <ul class="misc__items">
            {section.misc.map((item: string) => (
              <li class="misc__item">{item}</li>
            ))}
          </ul>
        </div>
      )
    }

    {
      section.playlist && (
        <div>
          <p>{section.playlist.text}Dude</p>
          <div>
            <iframe
              data-testid="embed-iframe"
              style="border-radius:12px"
              src={section.playlist.embed}
              width="100%"
              height="152"
              frameBorder="0"
              allowfullscreen=""
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
            />
          </div>
        </div>
      )
    }

    {
      section.tags && (
        <div class="section-tags section__tags">
          {section.tags.map((tag: string) => (
            <span class="section-tag section__tag body--micro">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</section>


  .content-section.is-visible {
    display: block;
    opacity: 1;
    transform: translateY(0);
    margin-bottom: var(--section-space-bottom);
  }

  .content-section.is-leaving {
    display: block;
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
    pointer-events: none;
  }

  /* Scroll mode: all sections visible */

---
import "../styles/global.css";
import content from "../data/content.json";
import Header from "../components/Header.astro";
import ContentSection from "../components/ContentSection.astro";
import ChatPanel from "../components/ChatPanel.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    <title>{content.meta.name} // {content.meta.vol}</title>
  </head>
  <body>
    <div class="l-page">
      <Header meta={content.meta} />
      <main class="main__content" id="js-main__content">
        <div class="scroll-mode__banner">
          // SCROLL MODE — all files accessible — type CHAT to return to
          directed mode
        </div>

        <!-- Content Sections -->
        <!---------------------------------- -->
        {
          content.sections.map((section, i) => (
            <ContentSection section={section} isDefault={i === 0} />
          ))
        }

        <!-- Offline Section -->
        <!---------------------------------- -->
        <div
          id="offline-section"
          class="offline-section"
          data-section-id="offline"
          style="display: none;"
        >
          <p class="offline-label">{content.offline.label}xx</p>
          <h2 class="offline-title">{content.offline.title}</h2>
          <p class="offline-message">{content.offline.message}</p>
          <button class="offline-cta">{content.offline.cta}</button>
        </div>
      </main>
      <!-- Chat panel -->
      <!---------------------------------- -->
      <ChatPanel chat={content.chat} />
    </div>

    <!-- Chat Scripts -->
    <!---------------------------------- -->
    <script>
      import { initChat } from "../scripts/chat.js";

      // Pass chat strings to JS at runtime
      const chatData = {
        welcome:
          "SIGNAL ESTABLISHED.\n\nWelcome to The Interrogation. I am the interface between you and the subject.\n\nState your directive:\n\n  0 — Intro\n  1 — BACKGROUND\n  2 — WORK\n  3 — PHILOSOPHY\n  4 — SKILLS\n\nOr type SCROLL to access all files simultaneously.\nType EXIT to terminate the session.",
        options:
          "  0 — Intro\n   1 — BACKGROUND\n  2 — WORK\n  3 — PHILOSOPHY\n  4 — SKILLS\n\nOr type SCROLL / EXIT.",
        unknown:
          "SIGNAL UNCLEAR. Input not recognized.\n\nRe-state your directive:",
        exitMessage:
          "SESSION TERMINATED.\n\nThank you for the interrogation. The subject has gone offline.\n\nType RESTART to reinitiate the sequence.",
        scrollActivated:
          "SCROLL MODE ACTIVATED.\nAll files now accessible simultaneously.\n\nType CHAT to return to directed mode.",
        chatRestored:
          "DIRECTED MODE RESTORED.\n\nSelect your next directive:\n\n  1 — BACKGROUND\n  2 — WORK\n  3 — PHILOSOPHY\n  4 — SKILLS",
        restart:
          "SEQUENCE REINITIATING...\n// session restored\n\nSIGNAL ESTABLISHED. Welcome back.\n\n  1 — BACKGROUND\n  2 — WORK\n  3 — PHILOSOPHY\n  4 — SKILLS\n\nOr type SCROLL / EXIT.",
        accessing: "ACCESSING FILE:",
      };

      document.addEventListener("DOMContentLoaded", () => {
        initChat(chatData);

        const themeToggle = document.getElementById("theme-toggle");
        themeToggle.addEventListener("click", () => {
          const isLight =
            document.documentElement.getAttribute("data-theme") === "light";
          if (isLight) {
            document.documentElement.removeAttribute("data-theme");
            localStorage.removeItem("theme");
          } else {
            document.documentElement.setAttribute("data-theme", "light");
            localStorage.setItem("theme", "light");
          }
        });
      });
    </script>
  </body>
</html>

---
import "../styles/global.css";
import content from "../data/content.json";
import Header from "../components/Header.astro";
import ContentSection from "../components/ContentSection.astro";
import ChatPanel from "../components/ChatPanel.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    <title>{content.meta.name} // {content.meta.vol}</title>
    <script is:inline>
      (function () {
        if (localStorage.getItem("theme") === "light")
          document.documentElement.setAttribute("data-theme", "light");
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Barlow + Plex -->
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Serif:ital,wght@0,300;0,400;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <!-- Work Sans + Space Grotesk -->
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Work+Sans:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="l-page">
      <Header meta={content.meta} />
      <main class="main__content" id="js-main__content">
        <div class="scroll-mode-banner scroll-mode__banner">
          <strong>SCROLL MODE</strong> — all files accessible — type CHAT to return
          to directed mode
        </div>

        <!-- Content Sections -->
        <!---------------------------------- -->
        {
          content.sections.map((section, i) => (
            <ContentSection section={section} isDefault={i === 0} />
          ))
        }

        <!-- Offline Section -->
        <!---------------------------------- -->
        <!-- <div
          id="offline-section"
          class="offline-section"
          data-section-id="offline"
          style="display: none;"
        >
          <p class="offline-label">{content.offline.label}xx</p>
          <h2 class="offline-title">{content.offline.title}</h2>
          <p class="offline-message">{content.offline.message}</p>
          <button class="offline-cta">{content.offline.cta}</button>
        </div> -->

        <div
          id="offline-section"
          class="offline-section"
          data-section-id="offline"
          style="display: none;"
        >
          <p class="offline-label">{content.offline.label}</p>
          <h2 class="offline-title">{content.offline.title}</h2>
          <p class="offline-message body--extra-large">
            {content.offline.message}
          </p>
          <div class="offline-video">
            <iframe
              src="https://www.youtube.com/embed/26aDVKqXop4?si=WwfBwKipHZgcRaZs"
              width="100%"
              height="100%"
              frameborder="0"
              allowfullscreen
              loading="lazy"></iframe>
          </div>
          <button class="offline-cta">{content.offline.cta}</button>
        </div>
      </main>
      <!-- Chat panel -->
      <!---------------------------------- -->
      <ChatPanel chat={content.chat} />
    </div>

    <!-- Chat Scripts -->
    <!---------------------------------- -->
    <script>
      import { initChat } from "../scripts/chat.js";

      // Pass chat strings to JS at runtime
      const chatData = {
        welcome:
          "SIGNAL ESTABLISHED.\n\nWelcome to Grantland. I am the interface between you and Grant.\n\nState your directive:\n\n  0 — INTRO\n  1 — FIRST DESIGN JOB\n  2 — TWO WEEKS OF CHANGE\n  3 — LONELINESS OF LONG DISTANCE RUNNING\n  4 — MY DESK IS A TV STUDIO\n\nOr type SCROLL to access all files simultaneously.\n\nType EXIT to terminate the session.",
        options:
          "Re-state your directive:\n\n  0 — INTRO\n  1 — FIRST DESIGN JOB\n  2 — TWO WEEKS OF CHANGE\n  3 — LONELINESS OF LONG DISTANCE RUNNING\n  4 — MY DESK IS A TV STUDIO\n\nOr type SCROLL / EXIT.",
        unknown: "SIGNAL UNCLEAR. Input not recognized.",
        exitMessage:
          "SESSION TERMINATED.\n\nThank you for the interrogation. The subject has gone offline.\n\nType RESTART to reinitiate the sequence.",
        scrollActivated:
          "SCROLL MODE ACTIVATED.\nAll files now accessible simultaneously.\n\nType CHAT to return to directed mode.",
        chatRestored:
          "DIRECTED MODE RESTORED.\n\nSelect your next directive:\n\n  0 — INTRO\n. 1 — FIRST DESIGN JOB\n  2 — TWO WEEKS OF CHANGE\n  3 — LONELINESS OF LONG DISTANCE RUNNING\n  4 — MY DESK IS A TV STUDIO",
        restart:
          "SEQUENCE REINITIATING...\n// session restored\n\nSIGNAL ESTABLISHED. Welcome back.\n\n  0 — INTRO\n. 1 — FIRST DESIGN JOB\n  2 — TWO WEEKS OF CHANGE\n  3 — LONELINESS OF LONG DISTANCE RUNNING\n  4 — MY DESK IS A TV STUDIO\n\nOr type SCROLL / EXIT.",
        accessing: "ACCESSING FILE:",
      };

      document.addEventListener("DOMContentLoaded", () => {
        initChat(chatData);

        const themeToggle = document.getElementById("theme-toggle");
        themeToggle.addEventListener("click", () => {
          const isLight =
            document.documentElement.getAttribute("data-theme") === "light";
          if (isLight) {
            document.documentElement.removeAttribute("data-theme");
            localStorage.removeItem("theme");
          } else {
            document.documentElement.setAttribute("data-theme", "light");
            localStorage.setItem("theme", "light");
          }
        });
      });
    </script>
  </body>
</html>

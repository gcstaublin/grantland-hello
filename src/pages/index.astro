---
import "../styles/global.css";
import content from "../data/content.json";
import Header from "../components/Header.astro";
import ContentSection from "../components/ContentSection.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />
    <title>{content.meta.name} // {content.meta.vol}</title>
  </head>
  <body>
    <div class="l-page">
      <Header meta={content.meta} />
      <main class="main__content" id="js-main__content">
        <div class="scroll-mode__banner">
          // SCROLL MODE — all files accessible — type CHAT to return to
          directed mode
        </div>

        <!-- Content Sections -->
        {
          content.sections.map((section, i) => (
            <ContentSection section={section} isDefault={i === 0} />
          ))
        }
      </main>
      <aside class="chat__panel" id="js-chat__panel"><div>chat</div></aside>
    </div>
  </body>
</html>
